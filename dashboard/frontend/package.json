{
  "name": "@cogent/dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "source ../ports.sh && next dev -p $DASHBOARD_FE_PORT",
    "clean": "rm -rf .next",
    "dev:clean": "rm -rf .next && source ../ports.sh && next dev -p $DASHBOARD_FE_PORT",
    "build": "next build",
    "start": "source ../ports.sh && next start -p $DASHBOARD_FE_PORT",
    "type-check": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0",
    "typescript": "5.9.3"
  }
}
