{
  "name": "@cogent/dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "mkdir -p .local && [ -f .local/dashboard_port ] || echo $((5200 + RANDOM % 800)) > .local/dashboard_port && next dev -p $(cat .local/dashboard_port)",
    "clean": "rm -rf .next",
    "dev:clean": "rm -rf .next && mkdir -p .local && [ -f .local/dashboard_port ] || echo $((5200 + RANDOM % 800)) > .local/dashboard_port && next dev -p $(cat .local/dashboard_port)",
    "build": "next build",
    "start": "mkdir -p .local && [ -f .local/dashboard_port ] || echo $((5200 + RANDOM % 800)) > .local/dashboard_port && next start -p $(cat .local/dashboard_port)",
    "type-check": "tsc --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0",
    "typescript": "5.9.3"
  }
}
