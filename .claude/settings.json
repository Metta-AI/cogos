{
  "enabledPlugins": {
    "pr-workflow@softmax-plugins": true
  },
  "extraKnownMarketplaces": {
    "softmax-plugins": {
      "source": {
        "source": "github",
        "repo": "Metta-AI/softmax-plugins"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; if [[ \"$f\" == *.py ]]; then ruff check \"$f\"; fi; }",
            "statusMessage": "Linting..."
          }
        ]
      }
    ]
  }
}
